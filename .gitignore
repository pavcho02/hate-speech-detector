# =========================
# Python cache files
# =========================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# =========================
# Virtual environments
# =========================
.venv/
venv/
env/
ENV/

# =========================
# Environment variables / secrets
# =========================
.env
.env.*
!.env.example

# =========================
# IDE / editor files
# =========================
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# =========================
# VS Code / temporary files
# =========================
tempCodeRunnerFile.py

# =========================
# Jupyter files, if created accidentally
# =========================
.ipynb_checkpoints/

# =========================
# Python build / packaging
# =========================
build/
dist/
*.egg-info/
.eggs/
*.egg
MANIFEST

# =========================
# Testing / coverage
# =========================
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
cover/

# =========================
# Type checker / linter cache
# =========================
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/

# =========================
# Project data
# Dataset files should not be committed.
# They can be downloaded/generated again using the scripts.
# =========================
data/raw/*
data/processed/*

!data/raw/.gitkeep
!data/processed/.gitkeep

# =========================
# Trained models
# Model files are large and should not be committed.
# =========================
models/*
!models/.gitkeep
!models/distilbert/.gitkeep
!models/naive_bayes/.gitkeep

# =========================
# Generated reports and outputs
# These are produced by evaluation scripts.
# =========================
reports/*.json
reports/*.txt
reports/*.csv
reports/figures/*
reports/error_analysis/*

!reports/.gitkeep
!reports/figures/.gitkeep
!reports/error_analysis/.gitkeep

# =========================
# ML model / binary files
# =========================
*.pkl
*.pickle
*.joblib
*.bin
*.pt
*.pth
*.ckpt
*.safetensors
*.onnx

# =========================
# Hugging Face / ML cache
# =========================
.cache/
huggingface/
.huggingface/
transformers_cache/
datasets_cache/

# =========================
# Logs
# =========================
*.log
logs/